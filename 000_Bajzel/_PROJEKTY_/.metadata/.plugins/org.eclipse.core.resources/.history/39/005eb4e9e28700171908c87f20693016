void movecursor(uint8_t LEN)
{
	y++;
	if (y>=wyswT[lcd].LIN)
		{
		y=0;
		if (((LEN+LEN-1)+x)<(wyswT[lcd].KOL))
		{
		x+=LEN;
		}
		else
		{
		lcd++;
		if (lcd>=SIZE(wyswT)) lcd=0;
		HD44780_NR(lcd,wyswT);
			HD44780_CUSTOMCHAR(0,znak);
		x=0;
		}

		}
HD44780_XY(x,y);
}
void delayms(uint16_t ms)
{
	while(ms--)
	{
		_delay_ms(1);
	}
}

