// like Arduino, works with PARASITE
void _OW_W1BIT(uint8_t BIT) // zapis BIT'u na magistralę  //static void _OW_W1BIT(uint8_t value)
{

	 _delay_us(1);
	 if(BIT & 0x01)
	 {
		 uint8_t sreg = SREG;
		 cli();
		 LOW(OW_PIN);
		 OUTPUT(OW_PIN);
		 _delay_us(10);
		 HIGH(OW_PIN);
		 SREG = sreg;
		 _delay_us(55);
	 }
	 else
	 {
		 uint8_t sreg = SREG;
		 cli();
		 LOW(OW_PIN);
		 OUTPUT(OW_PIN);
		 _delay_us(65);
		 HIGH(OW_PIN);
		 SREG = sreg;
		 _delay_us(5);

	 }

}

uint8_t _OW_R1BIT() // odczyt jednego BIT'u na magistralę //static uint8_t _OW_R1BIT()
{
	uint8_t BIT = 0;
	uint8_t sreg = SREG;
	 cli();

	 OUTPUT(OW_PIN);
	 LOW(OW_PIN);
	 _delay_us(1);
	 INPUT(OW_PIN);
	 _delay_us(10);
	 BIT = READ(OW_PIN);
	 SREG = sreg;
	 _delay_us(53); //też chyba do wywalenia ? raczej zmniejszenie na 45-50+1 żeby slot wynosić min 60us, tu ponad 91
	 return BIT;
}



void _OW_W8BIT(uint8_t OCTET, uint8_t PARASITE) // zapis OKTETU na magistralę + powerR dla PARASITE mode //static void onewire_write_byte(uint8_t value)
{
	 for(uint8_t i = 0; i < 8; i++)
	 {
	  _OW_W1BIT(OCTET & 0x01);
	  OCTET = OCTET >> 1;
	 }
	 if (!PARASITE)
		 {
		 uint8_t sreg = SREG;
		 cli();
		 INPUT(OW_PIN);
		 LOW(OW_PIN);
		 SREG = sreg;
		 }
}

uint8_t _OW_R8BIT()  // odczyt OKTETU na magistralę
{
	uint8_t OCTET = 0;
	 for(uint8_t i = 0; i < 8; i++)
	 {
		 OCTET = OCTET >> 1;
	  if(_OW_R1BIT()) OCTET |= 0x80;
	 }
	 return OCTET;
}


void OW_SELECT(const uint8_t *ID) // wybranie urządzenia po adresie (tablica 8 bajtów ID) //static void onewire_write_command(uint8_t *id)
{
	 OW_RESETPULSE();
	 if(ID)
	 {
	  _OW_W8BIT(OW_MATCHROM,_PARASITE);
	  for(uint8_t i = 0; i < 8; i++)
	   _OW_W8BIT(*ID++,_PARASITE);
	 }
	 else
	 {
	  _OW_W8BIT(OW_SKIPROM,_PARASITE);
	 }

}


void OW_RESETSEARCH() //reset przesukiwania One Wire, może do usunięcia //static void onewire_findinit()
{
	 _ow_LastDevice = 0;
	 _ow_LastDiscrepency = 0;
	 _ow_LastFamilyDiscrepency = 0;
	 _ow_last_buffer = 0;
}


void OW_SKIP() // pominięcie innych urządzeń (przy jednym czujniku)
{
	_OW_W8BIT(OW_SKIPROM,_PARASITE);
}


