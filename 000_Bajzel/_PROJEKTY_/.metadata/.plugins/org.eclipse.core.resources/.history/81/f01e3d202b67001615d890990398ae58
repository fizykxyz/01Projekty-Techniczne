uint8_t OW_RESETPULSE() // reset magistrali //static uint8_t onewire_reset() i tu będzie problem !! rozjebany
{


		uint8_t r;
		uint8_t retries = 125;
		uint8_t sreg = SREG;
		cli();
		INPUT(OW_PIN);
		SREG = sreg;

		// wait until the wire is high... just in case
		do {
			if (--retries == 0) return 0;
			_delay_us(2);
		} while ( !DIRECT_READ(reg, mask));

		sreg = SREG;
		cli();
		LOW(OW_PIN);
		OUTPUT(OW_PIN);
		SREG = sreg;
		delay_us(480);
		sreg = SREG;
		cli();
		INPUT(OW_PIN);	// allow it to float
		_delay_us(70);
		r = !READ(OW_PIN);
		SREG = sreg;
		_delay_us(410);
		return r;
	}
}


