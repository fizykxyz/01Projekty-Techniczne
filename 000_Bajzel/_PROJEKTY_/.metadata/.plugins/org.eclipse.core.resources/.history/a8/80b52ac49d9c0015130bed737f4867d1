int main()
{
//itoa();
	OUTPUT(ROT);
	HIGH(ROT);
	cli();
	GIMSK=(1<<INT0);		// Enable external interrupt INT0
	MCUCR=(1<<ISC01); //|(1<<ISC00);    // Setup INT0 for faling/rising edge detection

	OW_INIT();
//	GLCD_init();
//	GLCD_cls();


USART_Init();  // Initialise USART
OUTPUT(ALRPM);

TIMER0_INIT();
 char buf[15];
	uint8_t aID[8];
	uint8_t pos;
	int16_t temp;


//**********************************
	sei();         // enable all interrupts

	while(1){
		USART_SendText("Start skanowania magistrali" NL);

		_delay_ms(1000);
		USART_SendText(__DATE__ __TIME__);


					sprintf(buf," %02X%02X%02X \r\n",SIGNATURE_0,SIGNATURE_1,SIGNATURE_2);
					USART_SendText(TOSTRING(F_CPU));
					USART_SendText(TOSTRING(MCU));
							_delay_ms(1000);
		pos=0;
		Error=OW_OK;
		while (1)
		{
			pos=OW_SEARCH(OW_SearchROM, aID, pos);
//			if(pos==0){
//				USART_SendText("Koniec skanowania magistrali" NL);
//				break;
//			}

					//_delay_ms(750);
			OW_Start_Conversion(1);
			_delay_us(750);
			temp=OW_GetTemperature(&aID[0]);
			uint8_t crc=OW_CRC8(&aID[0],7);
			for(uint8_t i=0;i<8;i++)
				{
					sprintf(buf,"%02X",aID[i]);
					//GLCD_puttext(buf);
					USART_SendText(buf);

				}
				USART_SendText(" / pos: ");



				if (crc==aID[7]){
					USART_SendText("CRC OK.");
				}
					else
					{

						USART_SendText("CRC ERR");
				}
			    sprintf(buf,"%02X %d %+03i.%03i", crc ,pos, temp/16, (temp & 0b1111)*625);

							//GLCD_goto(0,36+ii*9);
							//GLCD_puttext(buf);
							USART_SendText(buf);
//							USART_SendText(NL);
				if (millis!=last){

					rpm=((rotary*60000)/(millis-last))/2;
					rotary=0;
					last=millis;
				}

 if (rpm<4000) TOGGLE(ALRPM);

							sprintf(buf," %05u rpm", rpm);
							USART_SendText(buf);
							USART_SendText(NL);
//


		}


}
