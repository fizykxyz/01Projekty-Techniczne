// Odczyt trybu zasilania dla danego czujnika
uint8_t DS18xxx_PARASITE(uint8_t *ID)
{
	  uint8_t PARASITE = EXT_POWER;
	  OW_RESETPULSE();
	  OW_COMMAND(ID, READ_POWERSUPPLY, EXT_POWER);
	  if (_OW_IO1BIT(1, EXT_POWER) == 0) PARASITE = PARASITE_MODE;
	  OW_RESETPULSE();
	  return PARASITE;
}


uint8_t DS18xxx_STARTMEAS(uint8_t *ID, uint8_t PARASITE)
{
	OW_RESETPULSE();
	OW_COMMAND(ID,START_CONVERT, PARASITE);
	return OW_OK;
}

// Odczyt notatnika (scratch) z czujnika ID do tablicy SCRACTH, odługości LEN
uint8_t DS18xxx_READSCRATCH(uint8_t *ID, uint8_t *SCRATCH, uint8_t LEN)
{
	//OW_RESETPULSE();
	OW_COMMAND(ID, READ_SCRATCH, EXT_POWER);
	for (uint8_t i=0;i<LEN;i++)
	{
		SCRATCH[i]=OW_R8BIT();
	}
	return OW_OK;
}



// Odczyt temperatury
uint16_t DS18xxx_CONVERT(uint8_t *ID, uint8_t PARASITE)
{

	uint16_t ret;
	DS18xxx_STARTMEAS(ID, PARASITE);
	_delay_ms(750);
	OW_COMMAND(ID, READ_SCRATCH, EXT_POWER);
	ret=OW_R8BIT();
	ret=ret|OW_R8BIT()<<8;

		if ( ret & 0x8000 )
		{
			ret ^= 0xffff;  // convert to positive => (twos complement)++
			ret++;
			ret|=0x8000;
		}
		return ret;
}


