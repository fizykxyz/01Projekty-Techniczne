uint8_t lcd,x,y;

void movecursor()
{
	y++;
	if (y>=wysw[lcd].LIN)
		{
		y=0;
		if ((31+x)<(wysw[lcd].KOL))
		{
		x+=16;
		}
		else
		{
		lcd++;
		if (lcd>=SIZE(wysw)) lcd=0;
		HD44780_NR(lcd,wysw);
			HD44780_CUSTOMCHAR(0,znak);
		x=0;
		}

		}
HD44780_XY(x,y);
}

